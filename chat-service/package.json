{
  "name": "shopgram-chat-service",
  "version": "1.0.0",
  "description": "Real-time chat service for ShopGram orders using Socket.io",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "pm2 stop shopgram-chat 2>/dev/null; nodemon server.js",
    "stop": "pm2 stop shopgram-chat",
    "prod": "pm2 restart shopgram-chat"
  },
  "keywords": [
    "chat",
    "socket.io",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
